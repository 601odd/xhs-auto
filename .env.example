# 小红书账号配置
XHS_USERNAME=你的手机号或邮箱
XHS_PASSWORD=你的密码

# OpenAI API配置（用于生成发帖内容）
OPENAI_API_KEY=你的OpenAI_API密钥
OPENAI_BASE_URL=https://api.openai.com/v1

# 小红书内推码
XHS_REFERRAL_CODE=你的内推码

# 浏览器配置
HEADLESS=false
BROWSER_TIMEOUT=30000
PAGE_TIMEOUT=10000

# 发帖配置
POST_INTERVAL_MIN=60
POST_INTERVAL_MAX=180
DAILY_POST_LIMIT=5

# 反检测配置
USE_STEALTH=true
USE_PROXY=false
PROXY_SERVER=

# 调试配置
DEBUG=false
SAVE_SCREENSHOTS=true