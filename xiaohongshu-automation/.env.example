# 服务器配置
PORT=3000
NODE_ENV=development

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# 验证码服务（可选）
CAPTCHA_TOKEN=your_2captcha_token_here

# 小红书配置
XHS_LOGIN_PHONE=your_phone_number
XHS_LOGIN_PASSWORD=your_password

# 其他配置
LOG_LEVEL=info